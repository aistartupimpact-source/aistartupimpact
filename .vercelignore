# Vercel Ignore File
# Files and directories to ignore during Vercel deployment

# Node modules (will be reinstalled)
node_modules/
**/node_modules/

# Build outputs
.next/
**/.next/
.turbo/
**/.turbo/
dist/
**/dist/
out/
**/out/

# Cache directories
.cache/
**/.cache/

# Local env files
.env.local
.env.*.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
**/.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Test coverage
coverage/
**/coverage/

# Temporary files
*.tmp
*.temp
.temp/
.tmp/
