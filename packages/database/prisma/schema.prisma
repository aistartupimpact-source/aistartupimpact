  headquartersCity                           String?
  stage                                      StartupStage             @default(SEED)
  totalFundingInr                            BigInt                   @default(0)
  employeeCount                              Int?
  isIndian                                   Boolean                  @default(true)
  isFeatured                                 Boolean                  @default(false)
  featuredUntil                              DateTime?
  impactScore                                Int                      @default(0)
  createdAt                                  DateTime                 @default(now())
  updatedAt                                  DateTime
  deletedAt                                  DateTime?
  founders                                   String[]                 @default([])
  foundersData                               Json?
  claimStatus                                ClaimStatus              @default(UNCLAIMED)
  claimedAt                                  DateTime?
  ownerId                                    String?
  submittedBy                                String?
  isVerified                                 Boolean                  @default(false)
  verifiedAt                                 DateTime?
  verificationToken                          String?                  @unique
  verifiedDomain                             String?
  claimedBy                                  String?
  searchVector                               Unsupported("tsvector")?
  category                                   String?                  @db.VarChar(100)
  businessType                               String?
  AiTool                                     AiTool[]
  Article                                    Article[]
  FundingRound                               FundingRound[]
  Job                                        Job[]
  StartupReview                              StartupReview[]
  SavedStartup                               SavedStartup[]
