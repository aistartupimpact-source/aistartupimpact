  @@index([claimedBy])
  @@index([impactScore])
  @@index([isFeatured])
  @@index([isIndian])
  @@index([isVerified])
  @@index([ownerId])
  @@index([searchVector], type: Gin)
  @@index([slug])
  @@index([stage])
}

