generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AIResearcher {
  id               String   @id
  name             String
  university       String
  position         String
  photoUrl         String?
  bio              String
  researchAreas    String[]
  notablePapers    String[]
  linkedinUrl      String?
  googleScholarUrl String?
  citations        Int      @default(0)
  hIndex           Int      @default(0)
  displayOrder     Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([displayOrder])
  @@index([isActive])
  @@index([university])
}

model AdCampaign {
  id               String         @id
  clientName       String
  clientEmail      String
  companyName      String
  companyLogo      String?
  status           CampaignStatus @default(DRAFT)
  startDate        DateTime
  endDate          DateTime
  totalBudgetPaise BigInt         @default(0)
  notes            String?
  createdBy        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  AdCreative       AdCreative[]

  @@index([startDate, endDate])
  @@index([status])
}

model AdClick {
  id          String     @id
  creativeId  String
  articleId   String?
  sessionHash String
  countryCode String?
  createdAt   DateTime   @default(now())
  AdCreative  AdCreative @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  @@index([creativeId, createdAt])
}

model AdCreative {
  id              String         @id
  campaignId      String
  zone            AdZoneType
  headline        String
  bodyText        String
  ctaText         String
  ctaUrl          String
  imageUrl        String?
  isActive        Boolean        @default(true)
  impressionCount Int            @default(0)
  clickCount      Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  AdClick         AdClick[]
  AdCampaign      AdCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  AdImpression    AdImpression[]

  @@index([campaignId])
  @@index([zone, isActive])
}

model AdImpression {
  id          String     @id
  creativeId  String
  articleId   String?
  sessionHash String
  countryCode String?
  createdAt   DateTime   @default(now())
  AdCreative  AdCreative @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  @@index([creativeId, createdAt])
}

model AffiliateClick {
  id          String   @id
  toolId      String
  sessionHash String
  ipAddress   String?
  referrer    String?
  createdAt   DateTime @default(now())
  AiTool      AiTool   @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId, createdAt])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model AiTool {
  id                  String                   @id
  name                String
  slug                String                   @unique
  tagline             String
  description         String
  websiteUrl          String
  affiliateUrl        String?
  logoUrl             String?
  screenshotUrls      String[]
  categoryId          String
  pricingModel        PricingModel             @default(FREEMIUM)
  freeTrialDays       Int?
  startingPrice       Int?
  hasApi              Boolean                  @default(false)
  hasMobileApp        Boolean                  @default(false)
  launchYear          Int?
  headquartersCountry String?
  founderNames        String[]
  avgRating           Float                    @default(0)
  reviewCount         Int                      @default(0)
  status              ToolApprovalStatus       @default(PENDING)
  isFeatured          Boolean                  @default(false)
  featuredUntil       DateTime?
  submittedBy         String?
  approvedBy          String?
  approvedAt          DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime
  deletedAt           DateTime?
  aiQualityScore      Int?
  aiSpamFlag          Boolean                  @default(false)
  aiSuggestedEdits    String[]
  clicks              Int                      @default(0)
  isUrlVerified       Boolean                  @default(false)
  listingTier         ListingTier              @default(FREE)
  paymentStatus       PaymentStatus            @default(PENDING)
  pendingTier         ListingTier?
  pricingUrl          String?
  razorpayOrderId     String?                  @unique
  razorpayPaymentId   String?                  @unique
  referralCode        String?                  @unique
  referredBy          String?
  startupId           String?
  tierExpiresAt       DateTime?
  claimStatus         ClaimStatus              @default(UNCLAIMED)
  claimedAt           DateTime?
  ownerId             String?
  searchVector        Unsupported("tsvector")?
  AffiliateClick      AffiliateClick[]
  ToolCategory        ToolCategory             @relation(fields: [categoryId], references: [id])
  FounderUser         FounderUser?             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  Startup             Startup?                 @relation(fields: [startupId], references: [id])
  Article             Article[]
  ToolCon             ToolCon[]
  ToolPro             ToolPro[]
  ToolReview          ToolReview[]
  ToolTag             ToolTag[]
  ToolTraffic         ToolTraffic[]
  ToolUseCase         ToolUseCase[]
  SavedTool           SavedTool[]

  @@index([avgRating])
  @@index([categoryId])
  @@index([claimStatus])
  @@index([isFeatured, status])
  @@index([ownerId])
  @@index([pricingModel])
  @@index([searchVector], type: Gin)
  @@index([slug])
  @@index([status])
  @@index([status, listingTier])
}

model Article {
  id                                            String                   @id
  title                                         String
  slug                                          String                   @unique
  excerpt                                       String?
  content                                       Json
  contentText                                   String?
  type                                          ArticleType              @default(NEWS)
  status                                        ArticleStatus            @default(DRAFT)
  authorId                                      String
  categoryId                                    String?
  coverImage                                    String?
  readTimeMinutes                               Int                      @default(1)
  wordCount                                     Int                      @default(0)
  viewCount                                     Int                      @default(0)
  shareCount                                    Int                      @default(0)
  isFeatured                                    Boolean                  @default(false)
  isPinned                                      Boolean                  @default(false)
  isSponsored                                   Boolean                  @default(false)
  sponsorId                                     String?
  seoTitle                                      String?
  seoDescription                                String?
  focusKeyword                                  String?
  ogImage                                       String?
  canonicalUrl                                  String?
  noIndex                                       Boolean                  @default(false)
  schemaType                                    String?
  scheduledAt                                   DateTime?
  publishedAt                                   DateTime?
  createdAt                                     DateTime                 @default(now())
  updatedAt                                     DateTime
  deletedAt                                     DateTime?
  thumbnailImage                                String?
  startupId                                     String?
  toolId                                        String?
  likeCount                                     Int                      @default(0)
  searchVector                                  Unsupported("tsvector")?
  User                                          User                     @relation(fields: [authorId], references: [id])
  Category                                      Category?                @relation(fields: [categoryId], references: [id])
  Startup                                       Startup?                 @relation(fields: [startupId], references: [id])
  AiTool                                        AiTool?                  @relation(fields: [toolId], references: [id])
  ArticleCoAuthor                               ArticleCoAuthor[]
  ArticleTag                                    ArticleTag[]
  ArticleVersion                                ArticleVersion[]
  Comment                                       Comment[]
  RelatedArticle_RelatedArticle_fromIdToArticle RelatedArticle[]         @relation("RelatedArticle_fromIdToArticle")
  RelatedArticle_RelatedArticle_toIdToArticle   RelatedArticle[]         @relation("RelatedArticle_toIdToArticle")

  @@index([authorId])
  @@index([categoryId])
  @@index([isFeatured, status])
  @@index([searchVector], type: Gin)
  @@index([slug])
  @@index([status, publishedAt])
  @@index([type, status])
}

model ArticleCoAuthor {
  articleId String
  userId    String
  Article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  User      User    @relation(fields: [userId], references: [id])

  @@id([articleId, userId])
}

model ArticleTag {
  articleId String
  tagId     String
  Article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  Tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model ArticleVersion {
  id        String   @id
  articleId String
  content   Json
  title     String
  createdAt DateTime @default(now())
  Article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, createdAt])
}

model AuditLog {
  id           String   @id
  userId       String
  action       String
  resourceType String
  resourceId   String?
  before       Json?
  after        Json?
  ipAddress    String?
  createdAt    DateTime @default(now())
  User         User     @relation(fields: [userId], references: [id])

  @@index([resourceType, createdAt])
  @@index([userId])
}

model BreakingTicker {
  id        String   @id
  text      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([isActive, sortOrder])
}

model Category {
  id             String     @id
  name           String
  slug           String     @unique
  description    String?
  icon           String?
  color          String?
  parentId       String?
  sortOrder      Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime
  Article        Article[]
  Category       Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  other_Category Category[] @relation("CategoryToCategory")

  @@index([parentId])
  @@index([slug])
}

model CityDeepDive {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cityId                 String?   @db.Uuid
  cityName               String
  slug                   String    @unique
  tagline                String?
  longDescription        String?
  totalStartups          Int?      @default(0)
  totalFunding           BigInt?   @default(0)
  mlEngineers            Int?
  averageSalary          BigInt?
  topStartups            Json?
  keyAccelerators        Json?
  majorCompanies         String[]
  topUniversities        String[]
  coworkingSpaces        String[]
  majorEvents            String[]
  reportPrice            Int?      @default(299900)
  reportUrl              String?
  featuredPlacementPrice Int?      @default(1500000)
  isFeatured             Boolean?  @default(false)
  displayOrder           Int?      @default(0)
  isActive               Boolean?  @default(true)
  createdAt              DateTime? @default(now()) @db.Timestamp(6)
  updatedAt              DateTime? @default(now()) @db.Timestamp(6)
}

model Comment {
  id            String        @id
  articleId     String
  userId        String?
  parentId      String?
  name          String?
  email         String?
  body          String
  status        CommentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  Article       Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  Comment       Comment?      @relation("CommentToComment", fields: [parentId], references: [id])
  other_Comment Comment[]     @relation("CommentToComment")
  User          User?         @relation(fields: [userId], references: [id])

  @@index([articleId, status])
  @@index([parentId])
}

model FeaturedFounder {
  id            String   @id
  name          String
  startupName   String
  startupSlug   String?
  photoUrl      String?
  bio           String
  achievement   String
  fundingRaised String?
  category      String
  linkedinUrl   String?
  twitterUrl    String?
  storyUrl      String?
  displayOrder  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([displayOrder])
  @@index([isActive])
}

model FounderAnalytics {
  id            String      @id
  userId        String
  entityType    String
  entityId      String
  date          DateTime    @db.Date
  views         Int         @default(0)
  clicks        Int         @default(0)
  inquiries     Int         @default(0)
  favorites     Int         @default(0)
  shares        Int         @default(0)
  directViews   Int         @default(0)
  searchViews   Int         @default(0)
  socialViews   Int         @default(0)
  referralViews Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  FounderUser   FounderUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId, date])
  @@index([entityType, entityId, date])
  @@index([userId, date])
}

model FounderNotification {
  id          String      @id
  userId      String
  type        String
  title       String
  message     String
  link        String?
  read        Boolean     @default(false)
  createdAt   DateTime    @default(now())
  FounderUser FounderUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, read])
}

model FounderSession {
  id          String      @id
  userId      String
  token       String      @unique
  expiresAt   DateTime
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())
  FounderUser FounderUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([token])
  @@index([userId])
}

model FounderUser {
  id                                     String                   @id
  email                                  String                   @unique
  name                                   String
  passwordHash                           String?
  company                                String?
  role                                   String?
  phone                                  String?
  avatar                                 String?
  bio                                    String?
  linkedin                               String?
  twitter                                String?
  website                                String?
  emailVerified                          Boolean                  @default(false)
  verifyToken                            String?                  @unique
  resetToken                             String?                  @unique
  resetExpiry                            DateTime?
  status                                 FounderUserStatus        @default(PENDING_VERIFICATION)
  createdAt                              DateTime                 @default(now())
  updatedAt                              DateTime
  lastLoginAt                            DateTime?
  authProvider                           String                   @default("email")
  companyDomain                          String?
  googleId                               String?                  @unique
  onboardingCompleted                    Boolean                  @default(false)
  onboardingStep                         Int                      @default(0)
  twoFactorEnabled                       Boolean                  @default(false)
  twoFactorSecret                        String?
  twoFactorBackupCodes                   String[]
  AiTool                                 AiTool[]
  FounderAnalytics                       FounderAnalytics[]
  FounderNotification                    FounderNotification[]
  FounderSession                         FounderSession[]
  Startup_Startup_claimedByToFounderUser Startup[]                @relation("Startup_claimedByToFounderUser")
  Startup_Startup_ownerIdToFounderUser   Startup[]                @relation("Startup_ownerIdToFounderUser")
  StartupVerificationLog                 StartupVerificationLog[]
  founder_settings                       founder_settings?

  @@index([companyDomain])
  @@index([email])
  @@index([googleId])
  @@index([resetToken])
  @@index([status])
  @@index([verifyToken])
}

model FundingDigest {
  id          String   @id
  title       String
  date        DateTime @db.Date
  status      String   @default("DRAFT")
  dealsCount  Int      @default(0)
  totalRaised String
  deals       Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([date])
  @@index([status])
}

model FundingRound {
  id            String   @id
  startupId     String
  roundType     String
  amountInr     BigInt
  amountUsd     BigInt?
  announcedAt   DateTime
  leadInvestors String[]
  allInvestors  String[]
  valuation     BigInt?
  sourceUrl     String?
  createdAt     DateTime @default(now())
  Startup       Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@index([announcedAt])
  @@index([roundType])
  @@index([startupId, announcedAt])
}

model GlossaryTerm {
  id           String   @id
  term         String
  slug         String   @unique
  definition   String
  relatedTerms String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@index([slug])
}

model GovernmentScheme {
  id                  String   @id
  name                String
  shortName           String
  fundingAmount       String
  eligibility         String[]
  applicationDeadline String
  status              String   @default("Open")
  applyLink           String
  description         String
  benefits            String[]
  category            String
  state               String?
  displayOrder        Int      @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([category])
  @@index([displayOrder])
  @@index([isActive])
  @@index([status])
}

model HeroSlot {
  id              String    @id
  title           String?
  ctaUrl          String?
  sortOrder       Int       @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  articleId       String?
  imageUrl        String?
  subtitle        String?
  authorName      String?
  badgeText       String?
  coverImage      String?
  ctaLabel        String?
  endDate         DateTime?
  excerpt         String?
  readTimeMinutes Int?
  startDate       DateTime?

  @@index([isActive, sortOrder])
}

model IndiaAICity {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cityName         String    @unique
  slug             String    @unique
  state            String?
  latitude         Decimal   @db.Decimal(10, 8)
  longitude        Decimal   @db.Decimal(11, 8)
  totalStartups    Int?      @default(0)
  totalFunding     BigInt?   @default(0)
  topSectors       String[]
  recentFundings   Json?
  keyAccelerators  String[]
  notableCompanies String[]
  averageTeamSize  Int?
  averageFunding   BigInt?
  description      String?
  featuredImage    String?
  isFeatured       Boolean?  @default(false)
  premiumPlacement Boolean?  @default(false)
  premiumUntil     DateTime? @db.Timestamp(6)
  displayOrder     Int?      @default(0)
  isActive         Boolean?  @default(true)
  createdAt        DateTime? @default(now()) @db.Timestamp(6)
  updatedAt        DateTime? @default(now()) @db.Timestamp(6)

  @@index([isActive, displayOrder], map: "idx_indiaai_city_active")
  @@index([latitude, longitude], map: "idx_indiaai_city_location")
}

model IndiaAIFundingHighlight {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fundingRoundId String?   @db.Uuid
  startupId      String?   @db.Uuid
  isFeatured     Boolean?  @default(false)
  featuredUntil  DateTime? @db.Timestamp(6)
  displayOrder   Int?      @default(0)
  createdAt      DateTime? @default(now()) @db.Timestamp(6)
}

model IndiaAIMissionTracker {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  component       String
  budgetAllocated BigInt
  budgetDisbursed BigInt?   @default(0)
  description     String?
  keyInitiatives  String[]
  displayOrder    Int?      @default(0)
  isActive        Boolean?  @default(true)
  updatedAt       DateTime? @default(now()) @db.Timestamp(6)
}

model IndiaAIStats {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  metricKey    String    @unique
  metricLabel  String
  metricValue  String
  metricChange String?
  metricIcon   String?
  displayOrder Int?      @default(0)
  isActive     Boolean?  @default(true)
  lastUpdated  DateTime? @default(now()) @db.Timestamp(6)
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @db.Timestamp(6)
}

model IndianAITool {
  id            String   @id
  name          String
  slug          String   @unique
  tagline       String
  description   String
  logoUrl       String?
  websiteUrl    String
  category      String
  foundedYear   Int?
  fundingStatus String?
  totalFunding  String?
  headquarters  String?
  teamSize      String?
  features      String[]
  useCases      String[]
  isFeatured    Boolean  @default(false)
  displayOrder  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([displayOrder])
  @@index([isActive])
  @@index([isFeatured])
  @@index([slug])
}

model Investor {
  id                 String       @id
  name               String
  slug               String       @unique
  type               InvestorType @default(VC)
  websiteUrl         String?
  logoUrl            String?
  description        String?
  focusAreas         String[]
  notableInvestments String[]
  totalDealsIndia    Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime

  @@index([slug])
  @@index([type])
}

model Job {
  id                String    @id
  startupId         String
  title             String
  description       String
  location          String?
  type              JobType   @default(REMOTE)
  salaryRangeMin    Int?
  salaryRangeMax    Int?
  postedBy          String?
  expiresAt         DateTime?
  applicationsCount Int       @default(0)
  isActive          Boolean   @default(true)
  isFeatured        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  deletedAt         DateTime?
  Startup           Startup   @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@index([isActive, type])
  @@index([isFeatured])
  @@index([startupId])
}

model LiveTicker {
  id        String   @id
  text      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([isActive, sortOrder])
}

model MediaAsset {
  id         String   @id
  url        String   @unique
  fileHash   String   @unique
  fileName   String
  mimeType   String
  sizeBytes  Int
  width      Int?
  height     Int?
  altText    String?
  uploadedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  User       User?    @relation(fields: [uploadedBy], references: [id])

  @@index([createdAt])
  @@index([fileHash])
  @@index([mimeType])
}

model NewsletterCampaign {
  id                    String                   @id
  subject               String
  previewText           String?
  contentJson           Json
  status                NewsletterCampaignStatus @default(DRAFT)
  scheduledAt           DateTime?
  sentAt                DateTime?
  totalSent             Int                      @default(0)
  opens                 Int                      @default(0)
  clicks                Int                      @default(0)
  unsubscribes          Int                      @default(0)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime
  bounces               Int                      @default(0)
  uniqueClicks          Int                      @default(0)
  uniqueOpens           Int                      @default(0)
  NewsletterClick       NewsletterClick[]
  NewsletterOpen        NewsletterOpen[]
  NewsletterUnsubscribe NewsletterUnsubscribe[]

  @@index([sentAt])
  @@index([status])
}

model NewsletterClick {
  id                 String             @id
  campaignId         String
  email              String
  linkUrl            String
  linkLabel          String?
  ipAddress          String?
  userAgent          String?
  clickedAt          DateTime           @default(now())
  NewsletterCampaign NewsletterCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, clickedAt])
  @@index([campaignId, email])
  @@index([campaignId])
  @@index([email])
}

model NewsletterOpen {
  id                 String             @id
  campaignId         String
  email              String
  ipAddress          String?
  userAgent          String?
  openedAt           DateTime           @default(now())
  NewsletterCampaign NewsletterCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, email])
  @@index([campaignId, openedAt])
  @@index([email])
}

model NewsletterSubscriber {
  id             String    @id
  email          String    @unique
  name           String?
  subscribedAt   DateTime  @default(now())
  source         String?
  isActive       Boolean   @default(true)
  tags           String[]
  lastOpenedAt   DateTime?
  lastClickedAt  DateTime?
  unsubscribedAt DateTime?

  @@index([email])
  @@index([isActive])
}

model NewsletterUnsubscribe {
  id                 String              @id
  campaignId         String?
  email              String
  reason             String?
  feedback           String?
  ipAddress          String?
  unsubscribedAt     DateTime            @default(now())
  NewsletterCampaign NewsletterCampaign? @relation(fields: [campaignId], references: [id])

  @@index([campaignId, unsubscribedAt])
  @@index([email])
  @@index([unsubscribedAt])
}

model PageView {
  id          String   @id
  pathname    String
  referrer    String?
  source      String
  device      String
  browser     String?
  os          String?
  country     String?
  sessionHash String
  ipHash      String?
  userAgent   String?
  duration    Int?
  bounced     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([device, createdAt])
  @@index([pathname, createdAt])
  @@index([sessionHash, createdAt])
  @@index([source, createdAt])
}

model PolicyUpdate {
  id           String   @id
  title        String
  source       String
  date         DateTime
  excerpt      String
  link         String
  category     String
  impact       String   @default("Medium")
  displayOrder Int      @default(0)
