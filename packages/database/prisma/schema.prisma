model Startup {
  id                                         String                   @id
  name                                       String
  slug                                       String                   @unique
  tagline                                    String
  description                                String
  logoUrl                                    String?
  websiteUrl                                 String?
  linkedinUrl                                String?
  twitterUrl                                 String?
