# Environment Variables for AIStartupImpact Development

# Database
DATABASE_URL="postgresql://aistartupimpact:aistartupimpact_dev@localhost:5432/aistartupimpact"

# Redis
REDIS_URL="redis://localhost:6379"

# Meilisearch
MEILI_URL="http://localhost:7700"
MEILI_MASTER_KEY="aistartupimpact_dev_key"

# Auth
JWT_SECRET="dev-jwt-secret-change-in-production-32chars"
REFRESH_SECRET="dev-refresh-secret-change-in-production"
NEXTAUTH_SECRET="dev-nextauth-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# API
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# AWS SES (configure for production)
AWS_SES_REGION="ap-south-1"
AWS_SES_ACCESS_KEY=""
AWS_SES_SECRET_KEY=""
SES_FROM_EMAIL="hello@aistartupimpact.com"

# Cloudflare R2 (configure for production)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="aistartupimpact-media"
R2_PUBLIC_URL=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
