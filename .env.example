# Database
DATABASE_URL="postgresql://user:password@host:5432/database"

# JWT Secrets
FOUNDER_JWT_SECRET="your-founder-jwt-secret-change-in-production"
ADMIN_JWT_SECRET="your-admin-jwt-secret-change-in-production"

# Google OAuth (Required for Google Sign-in)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/founder/auth/google/callback"

# Email Configuration (for verification emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@aistartupimpact.com"

# App URLs
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"

# Production URLs (uncomment for production)
# GOOGLE_REDIRECT_URI="https://yourdomain.com/api/founder/auth/google/callback"
# NEXT_PUBLIC_WEB_URL="https://yourdomain.com"
# NEXT_PUBLIC_ADMIN_URL="https://admin.yourdomain.com"
